<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Dashboard">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="63dp"
            android:scaleType="center"
            android:src="@drawable/rectangle_3" />

        <TextView
            android:id="@+id/profile"
            android:layout_width="170dp"
            android:layout_height="30dp"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:layout_marginStart="230dp"
            android:layout_marginTop="15dp"
            android:text="@string/profile_lembaga"
            android:textAppearance="@style/profile_lembaga" />

        <ImageView
            android:layout_width="41dp"
            android:layout_height="41dp"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:layout_marginStart="12dp"
            android:layout_marginTop="12dp"
            android:src="@drawable/mask_group" />


        <View
            android:id="@+id/ellipse_4"
            android:layout_width="157dp"
            android:layout_height="157dp"
            android:layout_alignParentLeft="true"
            android:layout_alignParentTop="true"
            android:layout_marginLeft="124dp"
            android:layout_marginTop="226dp"
            android:background="@drawable/bulat" />

        <TextView
            android:id="@+id/pkbm_darul_"
            android:layout_width="313dp"
            android:layout_height="53dp"
            android:layout_alignParentLeft="true"
            android:layout_alignParentTop="true"
            android:layout_marginLeft="1dp"
            android:layout_marginTop="426dp"
            android:gravity="top"
            android:text="Alamat: Jalan Mayong Pule No.KM 4, RT.04/RW.01, Kasong Penar, Buaran, Kec. Mayong, Kabupaten Jepara, Jawa Tengah 59465"
            android:textAppearance="@style/penjelasan_pkbm" />

        <TextView
            android:id="@+id/pkbm_darul_"
            android:layout_width="313dp"
            android:layout_height="53dp"
            android:layout_alignParentLeft="true"
            android:layout_alignParentTop="true"
            android:layout_marginLeft="-4dp"
            android:layout_marginTop="487dp"
            android:gravity="top"
            android:text=" Guru : 5
  Siswa Laki-laki : 110
  Siswa Perempuan : 45"
            android:textAppearance="@style/penjelasan_pkbm" />

        <TextView
            android:id="@+id/sistem_info"
            android:layout_width="170dp"
            android:layout_height="50dp"
            android:layout_alignParentLeft="true"
            android:layout_alignParentTop="true"
            android:layout_marginLeft="125dp"
            android:layout_marginTop="730dp"
            android:gravity="center_horizontal|top"
            android:text="@string/sistem_info"
            android:textAppearance="@style/sistem_info" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="360dp"
            android:src="@drawable/pkbm" />
</RelativeLayout>